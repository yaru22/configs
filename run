#!/bin/bash

# This script uses GNU Stow to symlink configuration files to your home directory.
# See https://www.gnu.org/software/stow/ for more information.

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR"

# Detect OS
OS="$(uname)"

# Common packages to stow
PACKAGES="git nvim alacritty vim ssh psql octave gem asciinema"

if [ "$OS" == "Darwin" ]; then
    echo "Detected macOS"
    PACKAGES="$PACKAGES bash-macos iterm vscode sublime"
elif [ "$OS" == "Linux" ]; then
    echo "Detected Linux"
    PACKAGES="$PACKAGES bash-ubuntu"
fi

if [[ "$(whoami)" == *agent* ]]; then
    echo "Agent environment detected. Overwriting container bash configs..."
    rm -f ~/.bashrc ~/.bash_aliases ~/.bash_profile ~/.profile
fi

echo "Stowing packages: $PACKAGES"
stow -t ~ $PACKAGES

echo "Done! Note: Emacs configurations (emacs-bare, emacs-doom, etc.) are not stowed automatically."
echo "To use one, e.g. Doom Emacs, run: stow -t ~ emacs-doom"
